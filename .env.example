PORT=4020
JWT_SECRET=change-me-in-production
APP_USER=admin
APP_PASSWORD=i9team

# Caminho para o arquivo teams.json do Claude Code
# Formato: { "projects": [{ "name": "...", "teams": [{ "name": "...", "agents": [...] }] }] }
TEAMS_JSON_PATH=/home/user/.claude/teams.json

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/i9_team_db

# Redis (usado pelo BullMQ para cleanup de uploads)
REDIS_HOST=localhost
REDIS_PORT=6379

# Diretório de uploads temporários (limpos automaticamente após 24h)
UPLOAD_DIR=/tmp/i9-team-uploads
